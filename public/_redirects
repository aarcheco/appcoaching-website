# Netlify SPA (Single Page Application) routing configuration
# This allows clean URLs to work with React Router / History API

# IMPORTANT: Netlify _redirects rules are matched top-to-bottom, first match wins.
# Specific static-file rules MUST come before the catch-all "/*" rule below,
# otherwise every asset request (images, JSON, etc.) gets swallowed by the
# catch-all and served index.html instead of the real file.

# Note: no explicit rules are needed for real static files (robots.txt, sitemap.xml,
# blog-posts.json, or the .md files in public/blog/) — Netlify always serves an existing
# file directly, before ever evaluating _redirects rules below. A rule such as
# "/blog/* /blog/:splat 200" was previously added here thinking it was needed for this,
# but it actually broke the site: it intercepted requests to CLIENT-SIDE blog post routes
# like /blog/my-post-slug (which are not real files, they're React routes) and rewrote them
# to themselves, which don't exist as files, producing a real HTTP 404 instead of falling
# through to index.html. This took down every blog post URL. Do not re-add a /blog/* rule.

# Rewrite all remaining requests to index.html while preserving the URL
# This tells Netlify to serve index.html for all requests that don't match static files
/*  /index.html  200

# Cache control headers for different file types
# Static assets with long cache duration
[[headers]]
  for = "/static/**"
  [headers.values]
    Cache-Control = "public, max-age=31536000, immutable"

# HTML files with no-cache to ensure fresh content
[[headers]]
  for = "/*.html"
  [headers.values]
    Cache-Control = "public, max-age=3600, must-revalidate"

# JSON files
[[headers]]
  for = "/*.json"
  [headers.values]
    Cache-Control = "public, max-age=3600"
