# Netlify SPA (Single Page Application) routing configuration
# This allows clean URLs to work with React Router / History API

# Rewrite all requests to index.html while preserving the URL
# This tells Netlify to serve index.html for all requests that don't match static files
/*  /index.html  200

# Specific rules for static files/assets (these take precedence over the catch-all rule above)
/robots.txt /robots.txt 200
/sitemap.xml /sitemap.xml 200
/blog-posts.json /blog-posts.json 200
/blog/* /blog/:splat 200

# Cache control headers for different file types
# Static assets with long cache duration
[[headers]]
  for = "/static/**"
  [headers.values]
    Cache-Control = "public, max-age=31536000, immutable"

# HTML files with no-cache to ensure fresh content
[[headers]]
  for = "/*.html"
  [headers.values]
    Cache-Control = "public, max-age=3600, must-revalidate"

# JSON files
[[headers]]
  for = "/*.json"
  [headers.values]
    Cache-Control = "public, max-age=3600"
